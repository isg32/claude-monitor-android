<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Row: Logo & Status Badge -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Small terminal indicator icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&gt;_"
                android:textColor="#8BCEFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claude Monitor"
                android:textColor="#E2E2E6"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Status Badges (Toggled in provider) -->
        <TextView
            android:id="@+id/widget_status_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:background="@drawable/widget_badge_bg_ok"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="Within Budget"
            android:textColor="#22C55E"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="visible" />

        <TextView
            android:id="@+id/widget_status_warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:background="@drawable/widget_badge_bg_warning"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="Usage Alert"
            android:textColor="#EAB308"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_status_alert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:background="@drawable/widget_badge_bg_alert"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="Over Limit"
            android:textColor="#EF4444"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Mid Row: Current Spend and Label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_cost_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_cost_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="4dp"
            android:text="this cycle"
            android:textColor="#858D99"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Progress Indicator -->
    <ProgressBar
        android:id="@+id/widget_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginBottom="12dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_bar" />

    <!-- Spacer to push content to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Row: Budget details & Refresh Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_budget_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limit: $100.00"
                android:textColor="#858D99"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_updated_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Just now"
                android:textColor="#4E5564"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Dynamic Refresh Button -->
        <TextView
            android:id="@+id/widget_refresh_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_button_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="Sync ↻"
            android:textColor="#8BCEFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>
</LinearLayout>
